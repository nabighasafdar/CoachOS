# Supabase (Project Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Backend API base URL (Android emulator uses 10.0.2.2, physical phone uses your LAN IP)
EXPO_PUBLIC_API_URL=http://localhost:8000

# Backend (services/api/.env) — copy from services/api/.env.example
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# USE_MOCK_TOOLS=true
# ACCOUNTABILITY_SECRET=coachos-dev-secret
