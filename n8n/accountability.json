{
  "name": "CoachOS Weekly Accountability",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * 1"
            }
          ]
        }
      },
      "id": "cron-1",
      "name": "Monday 09:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.COACHOS_API_URL}}/accountability/run",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"secret\": \"{{$env.COACHOS_ACCOUNTABILITY_SECRET}}\"\n}",
        "options": {}
      },
      "id": "http-1",
      "name": "Run Accountability",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [260, 0]
    }
  ],
  "connections": {
    "Monday 09:00": {
      "main": [[{ "node": "Run Accountability", "type": "main", "index": 0 }]]
    }
  },
  "meta": {
    "description": "Calls CoachOS POST /accountability/run weekly. Set COACHOS_API_URL and COACHOS_ACCOUNTABILITY_SECRET in n8n env."
  }
}
